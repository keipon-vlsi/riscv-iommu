"""
test_smoke.py — riscv_iommu Phase 1〜3 テスト

Phase 1 (Smoke):
    test_01〜05: リセット, レジスタ R/W, Bare 設定 ✅

Phase 2 (Bare passthrough):
    test_06, 07: Bare モードで dev_tr ↔ dev_comp 透過 ✅

Phase 3 (DDT translation, identity):
    test_08, 09: 1LVL DDT, 両 stage Bare, identity 翻訳 ✅

Phase 4 (PTW integration — メイン focus):
    test_10: Sv39 1-stage, 4K page  → PTW 3 段 walk
    test_11: Sv39 1-stage, 2M page  → PTW 2 段 walk (level-1 leaf)
    test_12: Sv39 1-stage, 1G page  → PTW 1 段 walk (level-2 leaf)

    各テストの構造:
      [ds_ram に DDT + PT を配置]
      [DC は固定: pdtv=0, fsc.mode=Sv39, fsc.ppn=PT root]
      [ddtp 設定 (1LVL, ppn=DDT base)]
      [comp_ram に既知データ]
      [dev_tr で IOVA を read]
      → IOMMU: DDT walk → DC cached
              IOTLB miss → PTW walks PT (← ★ ここを検証 ★)
              SPA 確定 → comp に forward
      [dev_tr.R で受けた値を検証]
"""

import logging

import cocotb
from cocotb.clock import Clock
from cocotb.triggers import RisingEdge
from cocotb.utils import get_sim_time

from cocotbext.axi import AxiBus, AxiMaster, AxiRam


# =============================================================================
# レジスタアドレス定義 (rv_iommu_reg_pkg.sv より)
# =============================================================================
REG_CAPABILITIES_L = 0x000
REG_CAPABILITIES_H = 0x004
REG_FCTL           = 0x008
REG_DDTP_L         = 0x010
REG_DDTP_H         = 0x014
REG_CQB_L          = 0x018
REG_CQB_H          = 0x01c
REG_FQB_L          = 0x028
REG_FQB_H          = 0x02c
REG_IPSR           = 0x054

# ddtp フィールド定義
DDTP_MODE_OFF   = 0x0
DDTP_MODE_BARE  = 0x1
DDTP_MODE_1LVL  = 0x2
DDTP_MODE_2LVL  = 0x3
DDTP_MODE_3LVL  = 0x4

DDTP_MODE_MASK  = 0xF
DDTP_BUSY_BIT   = 0x10  # bit[4]

# ddtp の PPN フィールド: bits [53:10] (44 bits)
DDTP_PPN_SHIFT  = 10

# DC レイアウト (Extended format = 64 bytes, MSI 有効)
DC_SIZE         = 64
DC_OFF_TC                  = 0      # tc      (8 bytes)
DC_OFF_IOHGATP             = 8      # iohgatp (8 bytes)
DC_OFF_TA                  = 16     # ta      (8 bytes)
DC_OFF_FSC                 = 24     # fsc     (8 bytes)
DC_OFF_MSIPTP              = 32     # msiptp  (8 bytes)
DC_OFF_MSI_ADDR_MASK       = 40
DC_OFF_MSI_ADDR_PATTERN    = 48
DC_OFF_RESERVED            = 56     # 読まれない (CDW skips last DW)

# DC.tc bit definitions (per RISC-V IOMMU spec)
TC_V        = 1 << 0    # Valid
TC_EN_ATS   = 1 << 1
TC_EN_PRI   = 1 << 2
TC_T2GPA    = 1 << 3
TC_DTF      = 1 << 4
TC_PDTV     = 1 << 5    # Process Directory valid (= fsc holds pdtp)
TC_PRPR     = 1 << 6
TC_GADE     = 1 << 7
TC_SADE     = 1 << 8
TC_DPE      = 1 << 9
TC_SBE      = 1 << 10
TC_SXL      = 1 << 11

# iohgatp / fsc mode encoding
ATGP_MODE_BARE  = 0     # Bare (no translation)
ATGP_MODE_SV39  = 8
ATGP_MODE_SV48  = 9
ATGP_MODE_SV57  = 10

# =============================================================================
# Sv39 PTE / Page Table 定義
# =============================================================================
# PTE フォーマット:
#   bits [9:0]  : flags + RSW
#   bits [53:10]: PPN (44 bits)
#   bits [63:54]: reserved
PTE_V = 1 << 0      # Valid
PTE_R = 1 << 1      # Read
PTE_W = 1 << 2      # Write
PTE_X = 1 << 3      # eXecute
PTE_U = 1 << 4      # User accessible
PTE_G = 1 << 5      # Global
PTE_A = 1 << 6      # Accessed
PTE_D = 1 << 7      # Dirty

# 「フル権限の leaf PTE」用フラグセット (R/W/X 全部, A/D セット, U=1)
PTE_LEAF_RWX_AD = PTE_V | PTE_R | PTE_W | PTE_X | PTE_U | PTE_A | PTE_D

# 「non-leaf PTE」(中間の page directory entry): V のみ立てる (R/W/X は全 0)
PTE_NONLEAF = PTE_V


def make_pte(ppn: int, flags: int) -> bytes:
    """Sv39 PTE 1 個を 8 byte で構築。"""
    pte = (flags & 0x3FF) | ((ppn & 0xFFFFFFFFFFF) << 10)
    return pte.to_bytes(8, "little")


def vpn_indices(iova: int):
    """Sv39 の VPN を 3 つに分解。
    iova = vpn[2..0] | offset(12bit)
      vpn[2] = bits 38..30  (root level)
      vpn[1] = bits 29..21  (mid)
      vpn[0] = bits 20..12  (leaf)
    """
    vpn2 = (iova >> 30) & 0x1FF
    vpn1 = (iova >> 21) & 0x1FF
    vpn0 = (iova >> 12) & 0x1FF
    return vpn2, vpn1, vpn0


def setup_sv39_4k(ds_ram, root_ppn: int, mid_ppn: int, leaf_ppn: int,
                  iova: int, sp_ppn: int,
                  perms: int = PTE_LEAF_RWX_AD):
    """Sv39 で iova → (sp_ppn << 12 + offset) の 4K mapping を構築。

    使う PT ページ:
      root_ppn (level 2) — 1 entry を mid_ppn に向ける
      mid_ppn  (level 1) — 1 entry を leaf_ppn に向ける
      leaf_ppn (level 0) — 1 entry を sp_ppn に向ける (leaf)

    各 PT ページは事前に 0 クリア。
    """
    vpn2, vpn1, vpn0 = vpn_indices(iova)

    # 全 PT ページを 0 クリア
    for ppn in (root_ppn, mid_ppn, leaf_ppn):
        ds_ram.write(ppn << 12, bytes(4096))

    # Root: vpn2 のスロットに mid_ppn を指す non-leaf PTE
    ds_ram.write((root_ppn << 12) + vpn2 * 8, make_pte(mid_ppn, PTE_NONLEAF))

    # Mid: vpn1 のスロットに leaf_ppn を指す non-leaf PTE
    ds_ram.write((mid_ppn << 12)  + vpn1 * 8, make_pte(leaf_ppn, PTE_NONLEAF))

    # Leaf: vpn0 のスロットに sp_ppn を指す leaf PTE
    ds_ram.write((leaf_ppn << 12) + vpn0 * 8, make_pte(sp_ppn, perms))


def setup_sv39_2m(ds_ram, root_ppn: int, mid_ppn: int,
                  iova: int, sp_ppn: int,
                  perms: int = PTE_LEAF_RWX_AD):
    """Sv39 で iova → 2M superpage の mapping を構築。

    level 1 (mid) PTE が leaf 扱い。leaf PT は不要。
    sp_ppn は 2M aligned (下位 9 bit が 0) にすること。
    """
    vpn2, vpn1, _ = vpn_indices(iova)

    for ppn in (root_ppn, mid_ppn):
        ds_ram.write(ppn << 12, bytes(4096))

    ds_ram.write((root_ppn << 12) + vpn2 * 8, make_pte(mid_ppn, PTE_NONLEAF))
    ds_ram.write((mid_ppn  << 12) + vpn1 * 8, make_pte(sp_ppn, perms))


def setup_sv39_1g(ds_ram, root_ppn: int,
                  iova: int, sp_ppn: int,
                  perms: int = PTE_LEAF_RWX_AD):
    """Sv39 で iova → 1G superpage の mapping を構築。

    level 2 (root) PTE が leaf 扱い。mid/leaf PT は不要。
    sp_ppn は 1G aligned (下位 18 bit が 0) にすること。
    """
    vpn2, _, _ = vpn_indices(iova)

    ds_ram.write(root_ppn << 12, bytes(4096))
    ds_ram.write((root_ppn << 12) + vpn2 * 8, make_pte(sp_ppn, perms))


# =============================================================================
# Sv39 用 DC とセットアップ
# =============================================================================
def build_dc_sv39_s1(s1_root_ppn: int) -> bytes:
    """1-stage Sv39, 2-stage Bare, no PC の DC を構築。

    PTW が S1 walk を実行する状態 (testing target)。
    """
    return build_dc(
        tc_bits      = TC_V,                 # V のみ (pdtv=0)
        iohgatp_mode = ATGP_MODE_BARE,       # G-stage は Bare
        fsc_mode     = ATGP_MODE_SV39,       # S-stage は Sv39
        fsc_ppn      = s1_root_ppn,          # PT root
    )


async def setup_iommu_for_sv39_s1(dut, prog_master, ds_ram, *,
                                   ddt_base_ppn: int,
                                   did: int,
                                   s1_root_ppn: int):
    """1LVL DDT に Sv39 S1 用 DC を 1 個置いて IOMMU を mode=1LVL に設定。"""
    log = logging.getLogger("cocotb.tb")

    # DC を DDT に配置
    dc = build_dc_sv39_s1(s1_root_ppn)
    dc_addr = (ddt_base_ppn << 12) + (did & 0x3F) * 64
    ds_ram.write(dc_addr, dc)
    log.info(f"  DC for did={did}: ds_ram[0x{dc_addr:x}] "
             f"(fsc.mode=Sv39, fsc.ppn=0x{s1_root_ppn:x})")

    # ddtp 設定
    await configure_ddt_mode(dut, prog_master,
                             mode=DDTP_MODE_1LVL,
                             ddt_base_ppn=ddt_base_ppn)


# =============================================================================
# 共通ヘルパ
# =============================================================================
async def reset_dut(dut, cycles: int = 10):
    """アクティブ Low リセットを cycles サイクルアサート → 解除。

    新しい dev_tr / dev_comp 信号も含めて、全 AXI 入力を 0 に初期化してから
    リセットを駆動する。X 値が IOMMU 内部に伝搬すると挙動が予測不能になる。
    """
    log = logging.getLogger("cocotb.tb")

    # ---- prog インターフェース (Slave AXI) ----
    prog_signals = [
        "prog_awid", "prog_awaddr", "prog_awlen", "prog_awsize", "prog_awburst",
        "prog_awlock", "prog_awcache", "prog_awprot", "prog_awqos", "prog_awregion",
        "prog_awatop", "prog_awuser", "prog_awvalid",
        "prog_wdata", "prog_wstrb", "prog_wlast", "prog_wuser", "prog_wvalid",
        "prog_bready",
        "prog_arid", "prog_araddr", "prog_arlen", "prog_arsize", "prog_arburst",
        "prog_arlock", "prog_arcache", "prog_arprot", "prog_arqos", "prog_arregion",
        "prog_aruser", "prog_arvalid",
        "prog_rready",
    ]

    # ---- dev_tr インターフェース (Slave AXI + DVM 拡張) ----
    tr_signals = [
        "tr_awid", "tr_awaddr", "tr_awlen", "tr_awsize", "tr_awburst",
        "tr_awlock", "tr_awcache", "tr_awprot", "tr_awqos", "tr_awregion",
        "tr_awatop", "tr_awuser", "tr_awvalid",
        # DVM 拡張 (AW)
        "tr_aw_stream_id", "tr_aw_ss_id_valid", "tr_aw_substream_id",
        "tr_wdata", "tr_wstrb", "tr_wlast", "tr_wuser", "tr_wvalid",
        "tr_bready",
        "tr_arid", "tr_araddr", "tr_arlen", "tr_arsize", "tr_arburst",
        "tr_arlock", "tr_arcache", "tr_arprot", "tr_arqos", "tr_arregion",
        "tr_aruser", "tr_arvalid",
        # DVM 拡張 (AR)
        "tr_ar_stream_id", "tr_ar_ss_id_valid", "tr_ar_substream_id",
        "tr_rready",
    ]

    # ---- dev_comp インターフェース (Master AXI 応答側) ----
    comp_signals = [
        "comp_awready", "comp_wready",
        "comp_bid", "comp_bresp", "comp_buser", "comp_bvalid",
        "comp_arready",
        "comp_rid", "comp_rdata", "comp_rresp", "comp_rlast", "comp_ruser", "comp_rvalid",
    ]

    # ---- ds インターフェース (Master AXI 応答側) ----
    ds_signals = [
        "ds_awready", "ds_wready",
        "ds_bid", "ds_bresp", "ds_buser", "ds_bvalid",
        "ds_arready",
        "ds_rid", "ds_rdata", "ds_rresp", "ds_rlast", "ds_ruser", "ds_rvalid",
    ]

    for sig in prog_signals + tr_signals + comp_signals + ds_signals:
        try:
            getattr(dut, sig).value = 0
        except AttributeError:
            pass

    # アクティブ Low なので 0 で assert
    dut.rst_ni.value = 0
    log.info("Reset asserted")

    for _ in range(cycles):
        await RisingEdge(dut.clk_i)

    dut.rst_ni.value = 1
    log.info("Reset de-asserted")

    # 解除後の安定化待ち
    for _ in range(5):
        await RisingEdge(dut.clk_i)


def make_prog_master(dut):
    """prog インターフェース用 AxiMaster を生成。"""
    bus = AxiBus.from_prefix(dut, "prog")
    return AxiMaster(bus, dut.clk_i, dut.rst_ni, reset_active_level=False)


def make_tr_master(dut):
    """dev_tr インターフェース用 AxiMaster を生成。
    DVM 拡張 (stream_id 等) は AxiBus に含まれないため、別途手動で駆動する。
    """
    bus = AxiBus.from_prefix(dut, "tr")
    return AxiMaster(bus, dut.clk_i, dut.rst_ni, reset_active_level=False)


def make_comp_ram(dut, size: int = 0x10000):
    """dev_comp インターフェース用 AxiRam を生成。
    内部にメモリを持ち、AXI Slave として AW/AR に応答する。
    """
    bus = AxiBus.from_prefix(dut, "comp")
    return AxiRam(bus, dut.clk_i, dut.rst_ni, reset_active_level=False, size=size)


def make_ds_ram(dut, size: int = 0x100000):
    """ds (Data Structures) インターフェース用 AxiRam を生成。
    DDT/PDT/PT/CQ/FQ/MSI 等を置く領域。1 MiB あれば十分。
    """
    bus = AxiBus.from_prefix(dut, "ds")
    return AxiRam(bus, dut.clk_i, dut.rst_ni, reset_active_level=False, size=size)


# =============================================================================
# Device Context (DC) ビルダ — Extended format (64 bytes)
# =============================================================================
def build_dc(*,
    tc_bits: int = TC_V,
    iohgatp_mode: int = 0,
    iohgatp_gscid: int = 0,
    iohgatp_ppn: int = 0,
    pscid: int = 0,
    fsc_mode: int = 0,
    fsc_ppn: int = 0,
    msiptp_mode: int = 0,
    msiptp_ppn: int = 0,
    msi_addr_mask: int = 0,
    msi_addr_pattern: int = 0,
) -> bytes:
    """64-byte DC エントリ (Extended format) を構築。
    bit position は RISC-V IOMMU spec section 2.1.4 に準拠。
    """
    dc = bytearray(DC_SIZE)

    # tc: 単純な bit OR
    tc = tc_bits

    # iohgatp: [3:0]=mode, [15:4]=gscid, [59:16]=ppn
    iohgatp = (iohgatp_mode & 0xF) | ((iohgatp_gscid & 0xFFF) << 4) | ((iohgatp_ppn & 0xFFFFFFFFFFF) << 16)

    # ta: [31:12]=pscid (20 bits)
    ta = (pscid & 0xFFFFF) << 12

    # fsc: [3:0]=mode, [43:4]=ppn (40 bits or 44 bits, spec dependent)
    fsc = (fsc_mode & 0xF) | ((fsc_ppn & 0xFFFFFFFFFFF) << 4)

    # msiptp: [3:0]=mode, [53:10]=ppn (44 bits at offset 10)
    msiptp = (msiptp_mode & 0xF) | ((msiptp_ppn & 0xFFFFFFFFFFF) << 10)

    dc[DC_OFF_TC:DC_OFF_TC+8]                           = tc.to_bytes(8, "little")
    dc[DC_OFF_IOHGATP:DC_OFF_IOHGATP+8]                 = iohgatp.to_bytes(8, "little")
    dc[DC_OFF_TA:DC_OFF_TA+8]                           = ta.to_bytes(8, "little")
    dc[DC_OFF_FSC:DC_OFF_FSC+8]                         = fsc.to_bytes(8, "little")
    dc[DC_OFF_MSIPTP:DC_OFF_MSIPTP+8]                   = msiptp.to_bytes(8, "little")
    dc[DC_OFF_MSI_ADDR_MASK:DC_OFF_MSI_ADDR_MASK+8]     = msi_addr_mask.to_bytes(8, "little")
    dc[DC_OFF_MSI_ADDR_PATTERN:DC_OFF_MSI_ADDR_PATTERN+8] = msi_addr_pattern.to_bytes(8, "little")
    # reserved DW (offset 56) は CDW が読まないので 0 のまま

    return bytes(dc)


def build_dc_identity() -> bytes:
    """両 stage Bare の最小 DC: tc.V=1, それ以外 0。
    1st-stage も 2nd-stage も翻訳しない = identity 動作。
    """
    return build_dc(tc_bits=TC_V)


# =============================================================================
# IOMMU 設定ヘルパ
# =============================================================================
async def configure_ddt_mode(dut, prog_master, *, mode: int, ddt_base_ppn: int):
    """ddtp に mode + PPN を一括書込みし、busy が落ちるまで待つ。"""
    log = logging.getLogger("cocotb.tb")

    ddtp_val = (ddt_base_ppn << DDTP_PPN_SHIFT) | (mode & DDTP_MODE_MASK)
    log.info(f"  Writing ddtp = 0x{ddtp_val:016x} (mode={mode}, ppn=0x{ddt_base_ppn:x})")

    await prog_master.write(REG_DDTP_L, ddtp_val.to_bytes(8, "little"))

    for i in range(200):
        op = await prog_master.read(REG_DDTP_L, 8)
        ddtp = int.from_bytes(op.data, "little")
        if not (ddtp & DDTP_BUSY_BIT):
            break
        await RisingEdge(dut.clk_i)
    else:
        raise AssertionError(f"busy still set: ddtp = 0x{ddtp:016x}")

    actual_mode = ddtp & DDTP_MODE_MASK
    assert actual_mode == mode, f"mode mismatch: expected {mode}, got {actual_mode}"
    log.info(f"  ddtp confirmed: 0x{ddtp:016x}")


async def configure_bare_mode(dut, prog_master):
    """IOMMU を Bare モードに設定し、busy bit が落ちるのを待つヘルパ。"""
    log = logging.getLogger("cocotb.tb")

    await prog_master.write(REG_DDTP_L, DDTP_MODE_BARE.to_bytes(8, "little"))

    # busy bit poll
    for i in range(100):
        op = await prog_master.read(REG_DDTP_L, 8)
        ddtp = int.from_bytes(op.data, "little")
        if not (ddtp & DDTP_BUSY_BIT):
            break
        await RisingEdge(dut.clk_i)
    else:
        raise AssertionError(f"busy still set: ddtp = 0x{ddtp:016x}")

    mode = ddtp & DDTP_MODE_MASK
    assert mode == DDTP_MODE_BARE, f"Expected Bare mode, got mode={mode}"
    log.info(f"  Bare mode set: ddtp = 0x{ddtp:016x}")


# =============================================================================
# Test 01: リセットだけ動かす
# =============================================================================
@cocotb.test()
async def test_01_reset_only(dut):
    """ビルドが通ってリセットが効くことだけ確認。"""
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())
    await reset_dut(dut, cycles=10)

    for _ in range(50):
        await RisingEdge(dut.clk_i)
        wsi_val = int(dut.wsi_wires_o.value)
        assert wsi_val == 0, f"WSI fired unexpectedly: 0x{wsi_val:x}"

    log.info("✓ Test 01 PASS — reset works, no spurious WSI")


# =============================================================================
# Test 02: capabilities レジスタを read
# =============================================================================
@cocotb.test()
async def test_02_read_capabilities(dut):
    """capabilities (RO, 64-bit) を 8 byte read してデフォルト値を確認。"""
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())

    master = make_prog_master(dut)
    await reset_dut(dut)

    log.info(f"Reading capabilities @ 0x{REG_CAPABILITIES_L:03x}")
    op = await master.read(REG_CAPABILITIES_L, 8)
    cap = int.from_bytes(op.data, "little")
    log.info(f"  capabilities = 0x{cap:016x}")

    assert cap != 0, "capabilities is zero — IOMMU initialization may have failed"

    log.info("✓ Test 02 PASS — capabilities read OK")


# =============================================================================
# Test 03: fctl レジスタの write → read
# =============================================================================
@cocotb.test()
async def test_03_write_read_fctl(dut):
    """fctl (RW, 32-bit) を書いて読み戻し検証。"""
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())

    master = make_prog_master(dut)
    await reset_dut(dut)

    op = await master.read(REG_FCTL, 4)
    init_val = int.from_bytes(op.data, "little")
    log.info(f"fctl initial = 0x{init_val:08x}")

    # 注意: fctl のリセット値は IGS=BOTH 構成で 0x2 (WSI=1)。
    # GXL bit (bit[2]) を立てる方が変化が見やすい。
    write_val = init_val ^ 0x4   # GXL bit を反転
    log.info(f"Writing 0x{write_val:08x} to fctl @ 0x{REG_FCTL:03x}")
    await master.write(REG_FCTL, write_val.to_bytes(4, "little"))

    for _ in range(5):
        await RisingEdge(dut.clk_i)

    op = await master.read(REG_FCTL, 4)
    read_val = int.from_bytes(op.data, "little")
    log.info(f"fctl read back = 0x{read_val:08x}")

    if read_val != init_val:
        log.info(f"  → 値が変化した (initial=0x{init_val:08x}, after=0x{read_val:08x})")
    else:
        log.warning(f"  → 値が変わらなかった (WARL ビット構成を要確認)")

    log.info("✓ Test 03 PASS — fctl write/read handshake completed")


# =============================================================================
# Test 04: 主要レジスタを一括 read
# =============================================================================
@cocotb.test()
async def test_04_register_dump(dut):
    """主要レジスタを順番に read してダンプ表示。"""
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())

    master = make_prog_master(dut)
    await reset_dut(dut)

    regs_64 = [
        ("capabilities", REG_CAPABILITIES_L),
        ("ddtp",         REG_DDTP_L),
        ("cqb",          REG_CQB_L),
        ("fqb",          REG_FQB_L),
    ]
    regs_32 = [
        ("fctl",         REG_FCTL),
        ("ipsr",         REG_IPSR),
    ]

    log.info("=== Register dump ===")
    for name, addr in regs_64:
        op = await master.read(addr, 8)
        val = int.from_bytes(op.data, "little")
        log.info(f"  {name:14s} @ 0x{addr:03x} = 0x{val:016x}")

    for name, addr in regs_32:
        op = await master.read(addr, 4)
        val = int.from_bytes(op.data, "little")
        log.info(f"  {name:14s} @ 0x{addr:03x} = 0x{val:08x}")

    log.info("✓ Test 04 PASS — register dump completed")


# =============================================================================
# Test 05: ddtp.iommu_mode を Bare に設定
# =============================================================================
@cocotb.test()
async def test_05_configure_bare_mode(dut):
    """ddtp.iommu_mode を Off (初期値) → Bare に設定。"""
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())

    master = make_prog_master(dut)
    await reset_dut(dut)

    op = await master.read(REG_DDTP_L, 8)
    init_ddtp = int.from_bytes(op.data, "little")
    init_mode = init_ddtp & DDTP_MODE_MASK
    log.info(f"Initial ddtp = 0x{init_ddtp:016x} (mode={init_mode})")
    assert init_mode == DDTP_MODE_OFF, f"Expected Off (0), got {init_mode}"

    log.info(f"Writing Bare mode")
    await configure_bare_mode(dut, master)

    log.info("✓ Test 05 PASS — IOMMU configured to Bare mode")


# =============================================================================
# Test 06: Bare モードで dev_tr → dev_comp の passthrough 検証 (Phase 2 入口)
#
# シナリオ:
#   1. IOMMU を Bare モードに設定
#   2. AxiRam (dev_comp 側) の 0x1000 番地に 64-bit データを書込み
#   3. AxiMaster (dev_tr 側) で 0x1000 から 8 byte read
#   4. Bare モードなので IOMMU は IOVA をそのまま物理アドレスとして渡す
#       → AxiRam の 0x1000 にアクセスして同じ値が返ってくるはず
#
# 観測ポイント (波形):
#   - tr_arvalid → tr_arready (cocotb → IOMMU の握手)
#   - comp_arvalid → comp_arready (IOMMU → AxiRam の握手, 同じ addr)
#   - comp_rvalid → comp_rready (AxiRam → IOMMU の応答)
#   - tr_rvalid → tr_rready (IOMMU → cocotb の応答)
# =============================================================================
@cocotb.test()
async def test_06_bare_mode_passthrough(dut):
    """Bare モードでデバイス→メモリの素通しを確認。"""
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())

    # ----- Setup: 3 つの AXI モデルを立ち上げる -----
    prog_master = make_prog_master(dut)
    tr_master   = make_tr_master(dut)
    comp_ram    = make_comp_ram(dut, size=0x10000)   # 64 KiB

    await reset_dut(dut)

    # ----- Step 1: IOMMU を Bare モードに -----
    log.info("[Step 1] Configure IOMMU to Bare mode")
    await configure_bare_mode(dut, prog_master)

    # ----- Step 2: AxiRam に既知データを置く -----
    test_addr = 0x1000
    test_data = 0xDEADBEEFCAFEBABE
    comp_ram.write(test_addr, test_data.to_bytes(8, "little"))
    log.info(f"[Step 2] Pre-populated comp_ram[0x{test_addr:x}] = 0x{test_data:016x}")

    # ----- Step 3: dev_tr 経由で同じ addr を read -----
    # DVM 拡張は reset_dut で 0 にしてあるのでそのまま (stream_id=0, no PV)
    log.info(f"[Step 3] Reading via dev_tr at addr 0x{test_addr:x}")
    op = await tr_master.read(test_addr, 8)
    read_val = int.from_bytes(op.data, "little")
    log.info(f"  Got: 0x{read_val:016x}")

    # ----- Step 4: 検証 -----
    assert read_val == test_data, \
        f"Bare passthrough failed: expected 0x{test_data:016x}, got 0x{read_val:016x}"

    log.info("✓ Test 06 PASS — Bare mode passthrough verified")


# =============================================================================
# Test 07: Bare モードで dev_tr → dev_comp の write passthrough
# =============================================================================
@cocotb.test()
async def test_07_bare_mode_write_passthrough(dut):
    """Bare モードで dev_tr に書込み → AxiRam に書かれることを確認。"""
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())

    prog_master = make_prog_master(dut)
    tr_master   = make_tr_master(dut)
    comp_ram    = make_comp_ram(dut, size=0x10000)

    await reset_dut(dut)
    await configure_bare_mode(dut, prog_master)

    # AxiRam の初期値 (0)
    test_addr = 0x2000
    test_data = 0x0123456789ABCDEF

    # dev_tr 経由で write
    log.info(f"Writing 0x{test_data:016x} to dev_tr addr 0x{test_addr:x}")
    await tr_master.write(test_addr, test_data.to_bytes(8, "little"))

    # 数サイクル待ってから AxiRam 内部を直接覗く (バッキング store が更新済みのはず)
    for _ in range(10):
        await RisingEdge(dut.clk_i)

    actual = int.from_bytes(comp_ram.read(test_addr, 8), "little")
    log.info(f"  comp_ram[0x{test_addr:x}] = 0x{actual:016x}")

    assert actual == test_data, \
        f"Write passthrough failed: expected 0x{test_data:016x}, got 0x{actual:016x}"

    log.info("✓ Test 07 PASS — Bare mode write passthrough verified")


# =============================================================================
# Test 08: 1LVL DDT, 両 stage Bare → identity 翻訳 (Phase 3 入口)
#
# シナリオ:
#   1. ds_ram に DC を 1 個配置 (stream_id=0 用)
#       - tc.V=1, 他は 0 → 両 stage Bare = identity
#   2. comp_ram に既知データを置く
#   3. IOMMU を 1LVL DDT モードに設定 (ddtp.iommu_mode=2, ppn=DDT base)
#   4. dev_tr で stream_id=0, IOVA=既知アドレス で read
#   5. 期待される内部動作:
#       a. DDTC miss → CDW が起動
#       b. CDW が ds 経由で DDT エントリ (DC) を fetch
#       c. DC を DDTC に登録
#       d. 両 stage Bare → trans_valid=1, spaddr=iova
#       e. dev_comp で IOVA と同じ addr で read
#   6. 検証: dev_tr に返ってきた値が事前配置データと一致
#
# 観測ポイント (Surfer / wave_report):
#   - ds_arvalid/araddr (CDW が DDT を読みに行く)
#   - ds_rvalid/rdata (DC データが返る)
#   - i_dut.i_rv_iommu_translation_wrapper.... 内部で DDTC update
#   - comp_arvalid/araddr (翻訳完了後にメモリへ)
#   - tr_rvalid/rdata (デバイスへ応答)
# =============================================================================
@cocotb.test(timeout_time=50, timeout_unit="us")
async def test_08_1lvl_ddt_identity(dut):
    """1LVL DDT, 両 stage Bare で identity 翻訳。"""
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())

    # ----- Setup: 4 つの AXI モデル -----
    prog_master = make_prog_master(dut)
    tr_master   = make_tr_master(dut)
    comp_ram    = make_comp_ram(dut, size=0x100000)   # 1 MiB
    ds_ram      = make_ds_ram(dut,   size=0x100000)   # 1 MiB (DDT を置く)

    await reset_dut(dut)

    # ----- Step 1: DDT を ds_ram に配置 -----
    DDT_BASE_PPN  = 0x10                         # 任意の 4K aligned PPN
    DDT_BASE_ADDR = DDT_BASE_PPN << 12           # = 0x10000

    did = 0
    # 1LVL + MSI 拡張時の DC offset = did[5:0] * 64
    dc_addr = DDT_BASE_ADDR + (did & 0x3F) * 64

    dc = build_dc_identity()
    ds_ram.write(dc_addr, dc)
    log.info(f"[Step 1] DC for did={did} placed at ds_ram[0x{dc_addr:x}]")
    log.info(f"         tc=0x{int.from_bytes(dc[0:8], 'little'):016x} "
             f"(V=1, all else 0 → both stages Bare)")

    # ----- Step 2: comp_ram に既知データ -----
    test_addr = 0x50000
    test_data = 0xCAFEF00DD00DBEEF
    comp_ram.write(test_addr, test_data.to_bytes(8, "little"))
    log.info(f"[Step 2] comp_ram[0x{test_addr:x}] = 0x{test_data:016x}")

    # ----- Step 3: IOMMU を 1LVL DDT モードに -----
    log.info(f"[Step 3] Configure IOMMU: mode=1LVL DDT, ppn=0x{DDT_BASE_PPN:x}")
    await configure_ddt_mode(dut, prog_master,
                             mode=DDTP_MODE_1LVL,
                             ddt_base_ppn=DDT_BASE_PPN)

    # ----- Step 4: dev_tr で read 発行 -----
    # DVM 拡張: stream_id=did, no PV
    dut.tr_ar_stream_id.value   = did
    dut.tr_ar_ss_id_valid.value = 0
    dut.tr_ar_substream_id.value = 0

    log.info(f"[Step 4] dev_tr.read(addr=0x{test_addr:x}, stream_id={did})")
    log.info(f"         IOMMU 内部で DDTC miss → CDW → ds 経由で DC fetch される")

    op = await tr_master.read(test_addr, 8)
    read_val = int.from_bytes(op.data, "little")
    log.info(f"  Got: 0x{read_val:016x}")

    # ----- Step 5: 検証 -----
    assert read_val == test_data, \
        f"Identity translation failed: expected 0x{test_data:016x}, got 0x{read_val:016x}"

    log.info("✓ Test 08 PASS — 1LVL DDT identity translation verified")
    log.info("  (DDTC miss → CDW → DC fetch → DDTC update → identity → comp 透過)")


# =============================================================================
# Test 09: test_08 の直後にもう一度同じ翻訳
#   → DDTC ヒット (キャッシュが効いていることを確認)
# =============================================================================
@cocotb.test(timeout_time=50, timeout_unit="us")
async def test_09_ddtc_hit(dut):
    """test_08 と同じ翻訳を 2 回連続で発行 → 2 回目は DDTC hit。

    注意: 同じシミュレーション内で test_08 の後に走るので、本来は
    DDTC にエントリが残っている可能性がある。が、各テスト先頭で
    reset_dut() してリセットしているので毎回まっさらから始まる。
    したがってこのテスト内で 2 回連続発行する。
    """
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())

    prog_master = make_prog_master(dut)
    tr_master   = make_tr_master(dut)
    comp_ram    = make_comp_ram(dut, size=0x100000)
    ds_ram      = make_ds_ram(dut,   size=0x100000)

    await reset_dut(dut)

    # 同じセットアップ
    DDT_BASE_PPN  = 0x10
    DDT_BASE_ADDR = DDT_BASE_PPN << 12
    did = 0
    dc_addr = DDT_BASE_ADDR + (did & 0x3F) * 64
    ds_ram.write(dc_addr, build_dc_identity())

    test_addr_a = 0x50000
    test_addr_b = 0x60000
    comp_ram.write(test_addr_a, (0x1111111111111111).to_bytes(8, "little"))
    comp_ram.write(test_addr_b, (0x2222222222222222).to_bytes(8, "little"))

    await configure_ddt_mode(dut, prog_master,
                             mode=DDTP_MODE_1LVL,
                             ddt_base_ppn=DDT_BASE_PPN)

    dut.tr_ar_stream_id.value = did
    dut.tr_ar_ss_id_valid.value = 0
    dut.tr_ar_substream_id.value = 0

    # 1 回目: DDTC miss → ds で DDT walk
    log.info("[Round 1] DDTC miss expected — first translation")
    t0 = get_sim_time(units="ns")
    op = await tr_master.read(test_addr_a, 8)
    t1 = get_sim_time(units="ns")
    val_a = int.from_bytes(op.data, "little")
    log.info(f"  Got 0x{val_a:016x} in {t1-t0:.0f} ns")
    assert val_a == 0x1111111111111111

    # 2 回目: 同じ stream_id → DDTC hit, ds は使われないはず
    log.info("[Round 2] DDTC hit expected — same stream_id, different addr")
    t0 = get_sim_time(units="ns")
    op = await tr_master.read(test_addr_b, 8)
    t1 = get_sim_time(units="ns")
    val_b = int.from_bytes(op.data, "little")
    log.info(f"  Got 0x{val_b:016x} in {t1-t0:.0f} ns")
    assert val_b == 0x2222222222222222

    log.info("✓ Test 09 PASS — DDTC hit on second translation")
    log.info("  (波形で ds_arvalid が 1 回しか立たないことを確認できる)")


# =============================================================================
# 共通: Sv39 PTW テスト用のリソース割り当て
# -----------------------------------------------------------------------------
# ds_ram (1 MiB) のメモリ map (各テストで共通):
#   0x10000  — 0x10FFF : DDT (1 page)
#   0x11000  — 0x11FFF : S1 page table root (level 2)
#   0x12000  — 0x12FFF : S1 page table mid  (level 1)
#   0x13000  — 0x13FFF : S1 page table leaf (level 0)
#   ...
#
# comp_ram (1 MiB) には翻訳結果アドレスにテストデータを置く
# =============================================================================
DDT_BASE_PPN  = 0x10
S1_ROOT_PPN   = 0x11
S1_MID_PPN    = 0x12
S1_LEAF_PPN   = 0x13


# =============================================================================
# Test 10: Sv39 1-stage 4K page translation (PTW 3 段 walk)
# =============================================================================
@cocotb.test(timeout_time=50, timeout_unit="us")
async def test_10_sv39_4k_page(dut):
    """Sv39 S1: 4K page で PTW 3 段 walk が成功する。

    シナリオ:
      - DC: pdtv=0, fsc.mode=Sv39, fsc.ppn=S1_ROOT_PPN
      - PT: 単一の 4K mapping (iova=0x002345 → SPA=0x100345)
      - dev_tr で 0x002345 を read

    観測:
      - ds_arvalid が 4 回 (DDT 1 + PT 3) 程度
      - i_dut.spaddr が 0x100345 (PPN + offset)
      - comp_araddr が 0x100345
    """
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())
    prog_master = make_prog_master(dut)
    tr_master   = make_tr_master(dut)
    # AxiRam は SparseMemory なので size を大きく取っても実 RAM は食わない
    comp_ram    = make_comp_ram(dut, size=0x100_000_000)   # 4 GiB sparse
    ds_ram      = make_ds_ram(dut,   size=0x100000)

    await reset_dut(dut)

    log.info("[Setup] Configure IOMMU for Sv39 S1, mode=1LVL DDT")
    await setup_iommu_for_sv39_s1(dut, prog_master, ds_ram,
                                   ddt_base_ppn=DDT_BASE_PPN,
                                   did=0,
                                   s1_root_ppn=S1_ROOT_PPN)

    # ---- 4K page mapping (小さいアドレスで) ----
    iova   = 0x002_345              # vpn2=0, vpn1=0, vpn0=0x2, off=0x345
    sp_ppn = 0x100                  # 4K aligned PPN → addr 0x100_000
    setup_sv39_4k(ds_ram,
                  root_ppn=S1_ROOT_PPN,
                  mid_ppn=S1_MID_PPN,
                  leaf_ppn=S1_LEAF_PPN,
                  iova=iova,
                  sp_ppn=sp_ppn)
    expected_spa = (sp_ppn << 12) | (iova & 0xFFF)
    log.info(f"[Map] iova=0x{iova:06x} → spa=0x{expected_spa:06x} (4K page)")

    test_data = 0xC0FFEE_BABE0123
    comp_ram.write(expected_spa, test_data.to_bytes(8, "little"))
    log.info(f"[Memory] comp_ram[0x{expected_spa:x}] = 0x{test_data:016x}")

    # ---- dev_tr 経由で read ----
    dut.tr_ar_stream_id.value   = 0
    dut.tr_ar_ss_id_valid.value = 0
    dut.tr_ar_substream_id.value = 0

    log.info(f"[Request] dev_tr.read(iova=0x{iova:06x})")
    op = await tr_master.read(iova, 8)
    read_val = int.from_bytes(op.data, "little")
    log.info(f"  Got: 0x{read_val:016x}")

    assert read_val == test_data, \
        f"4K walk failed: expected 0x{test_data:016x}, got 0x{read_val:016x}"

    log.info("✓ Test 10 PASS — Sv39 4K page walk verified")


# =============================================================================
# Test 11: Sv39 1-stage 2M superpage (PTW level-1 leaf 判定)
# =============================================================================
@cocotb.test(timeout_time=50, timeout_unit="us")
async def test_11_sv39_2m_superpage(dut):
    """Sv39 S1: 2M superpage で level-1 が leaf になる挙動。

    sp_ppn は 2M aligned (= 下位 9 bit が 0) であること。
    leaf PT (level 0) は使われない。
    """
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())
    prog_master = make_prog_master(dut)
    tr_master   = make_tr_master(dut)
    comp_ram    = make_comp_ram(dut, size=0x100_000_000)
    ds_ram      = make_ds_ram(dut,   size=0x100000)

    await reset_dut(dut)

    log.info("[Setup] Configure IOMMU for Sv39 S1")
    await setup_iommu_for_sv39_s1(dut, prog_master, ds_ram,
                                   ddt_base_ppn=DDT_BASE_PPN,
                                   did=0,
                                   s1_root_ppn=S1_ROOT_PPN)

    # 2M page mapping (小さいアドレスで)
    iova   = 0x123_456              # vpn2=0, vpn1=0, 2M off = 0x123_456
    sp_ppn = 0x200                  # 2M aligned: 下位 9 bit = 0

    setup_sv39_2m(ds_ram,
                  root_ppn=S1_ROOT_PPN,
                  mid_ppn=S1_MID_PPN,
                  iova=iova,
                  sp_ppn=sp_ppn)

    expected_spa = ((sp_ppn & ~0x1FF) << 12) | (iova & 0x1F_FFFF)
    log.info(f"[Map] iova=0x{iova:06x} → spa=0x{expected_spa:06x} (2M superpage)")

    test_data = 0x12345678_9ABCDEF0
    comp_ram.write(expected_spa, test_data.to_bytes(8, "little"))

    dut.tr_ar_stream_id.value = 0
    dut.tr_ar_ss_id_valid.value = 0
    dut.tr_ar_substream_id.value = 0

    log.info(f"[Request] dev_tr.read(iova=0x{iova:06x})")
    op = await tr_master.read(iova, 8)
    read_val = int.from_bytes(op.data, "little")
    log.info(f"  Got: 0x{read_val:016x}")

    assert read_val == test_data, \
        f"2M walk failed: expected 0x{test_data:016x}, got 0x{read_val:016x}"

    log.info("✓ Test 11 PASS — Sv39 2M superpage walk verified")


# =============================================================================
# Test 12: Sv39 1-stage 1G superpage (PTW level-2 leaf 判定)
# =============================================================================
@cocotb.test(timeout_time=50, timeout_unit="us")
async def test_12_sv39_1g_superpage(dut):
    """Sv39 S1: 1G superpage で level-2 (root) が leaf になる挙動。

    sp_ppn は 1G aligned (= 下位 18 bit が 0) であること。
    mid / leaf PT はどちらも使われない。
    """
    log = logging.getLogger("cocotb.tb")
    log.setLevel(logging.INFO)

    cocotb.start_soon(Clock(dut.clk_i, 10, units="ns").start())
    prog_master = make_prog_master(dut)
    tr_master   = make_tr_master(dut)
    comp_ram    = make_comp_ram(dut, size=0x100_000_000)
    ds_ram      = make_ds_ram(dut,   size=0x100000)

    await reset_dut(dut)

    log.info("[Setup] Configure IOMMU for Sv39 S1")
    await setup_iommu_for_sv39_s1(dut, prog_master, ds_ram,
                                   ddt_base_ppn=DDT_BASE_PPN,
                                   did=0,
                                   s1_root_ppn=S1_ROOT_PPN)

    # 1G page mapping (小さいアドレスで; vpn2=0, sp_ppn=0 → SPA = iova の下位 30bit)
    iova   = 0x123_4567              # vpn2=0, 下位 30 bit が 1G offset
    sp_ppn = 0x0                     # 1G aligned: 下位 18 bit = 0 (PPN=0 でも OK)

    setup_sv39_1g(ds_ram, root_ppn=S1_ROOT_PPN, iova=iova, sp_ppn=sp_ppn)

    expected_spa = ((sp_ppn & ~0x3_FFFF) << 12) | (iova & 0x3FFF_FFFF)
    log.info(f"[Map] iova=0x{iova:07x} → spa=0x{expected_spa:07x} (1G superpage)")

    test_data = 0xDEAD_BEEF_F00D_BAAD
    comp_ram.write(expected_spa, test_data.to_bytes(8, "little"))

    dut.tr_ar_stream_id.value = 0
    dut.tr_ar_ss_id_valid.value = 0
    dut.tr_ar_substream_id.value = 0

    log.info(f"[Request] dev_tr.read(iova=0x{iova:07x})")
    op = await tr_master.read(iova, 8)
    read_val = int.from_bytes(op.data, "little")
    log.info(f"  Got: 0x{read_val:016x}")

    assert read_val == test_data, \
        f"1G walk failed: expected 0x{test_data:016x}, got 0x{read_val:016x}"

    log.info("✓ Test 12 PASS — Sv39 1G superpage walk verified")
