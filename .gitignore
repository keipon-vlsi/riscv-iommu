# =============================================================================
# RISC-V IOMMU Verification .gitignore
# =============================================================================

# ---------------------------------------
# 1. シミュレーション成果物 (Cocotb / Verilator)
# ---------------------------------------
sim_build/
.cocotb_build/
*.vcd
*.fst
results.xml

# ---------------------------------------
# 2. ログファイル
# ---------------------------------------
*.log
# ただし、期待値ファイル(golden_*.jsonl)はGitで管理し、出力されたログ(rtl_log.jsonl等)は除外する
*.jsonl
!*golden*.jsonl

# ---------------------------------------
# 3. Pythonのキャッシュ
# ---------------------------------------
__pycache__/
*.py[cod]
*$py.class

# ---------------------------------------
# 4. C/C++ コンパイル成果物・カバレッジ (Verilator / third_party)
# ---------------------------------------
*.o
*.a
*.gcda
*.gcno
*.dSYM/
coverage.info
coverage_html/

# テストベクタ生成用の実行バイナリ（拡張子のないファイル）を除外
# ただし、ソースコード(.c, .h)は除外しない
tb_coco/test/reference/gen_vectors/gen_*
!tb_coco/test/reference/gen_vectors/*.c
!tb_coco/test/reference/gen_vectors/*.h

# ---------------------------------------
# 5. エディタ・OSの不要ファイル
# ---------------------------------------
.vscode/
.idea/
.DS_Store
*~
*.swp
*.swo
*.bak
:w  # Vimの操作ミスで生成されたファイル